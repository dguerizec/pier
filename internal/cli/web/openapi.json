{
  "openapi": "3.1.0",
  "info": {
    "title": "pier API",
    "version": "v1",
    "description": "REST API exposed by `pier serve`. Drives the same workload + worktree lifecycle as the pier CLI. Source: https://github.com/LeoPartt/pier",
    "license": { "name": "MIT" }
  },
  "servers": [
    { "url": "/", "description": "current server" }
  ],
  "tags": [
    { "name": "projects", "description": "Project (repo) registry — what pier knows about" },
    { "name": "workloads", "description": "Per-(project, slug) workload lifecycle" },
    { "name": "worktrees", "description": "Git worktree CRUD" },
    { "name": "infra", "description": "Pier install state and health" },
    { "name": "events", "description": "Server-Sent Events" }
  ],
  "paths": {
    "/api/v1/workloads": {
      "get": {
        "tags": ["workloads"],
        "summary": "List all workloads",
        "responses": {
          "200": {
            "description": "Sorted list (by project, then slug)",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Workload" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/workloads/{project}/{slug}": {
      "parameters": [
        { "name": "project", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "tags": ["workloads"],
        "summary": "Get one workload",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Workload" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/workloads/{project}/{slug}/up": {
      "parameters": [
        { "name": "project", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "post": {
        "tags": ["workloads"],
        "summary": "Bring the workload up (idempotent)",
        "description": "Returns 200 with current state when already running. Body is optional — provide `worktree_path` the first time a (project, slug) is brought up; subsequent calls can omit it (the previous state row carries the path).",
        "requestBody": {
          "required": false,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpRequest" } } }
        },
        "responses": {
          "200": { "description": "Running workload state", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Workload" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/v1/workloads/{project}/{slug}/down": {
      "parameters": [
        { "name": "project", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "post": {
        "tags": ["workloads"],
        "summary": "Stop the workload (idempotent)",
        "description": "Returns 200 with status=down even when no state row exists.",
        "responses": {
          "200": { "description": "Stopped", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ActionResponse" } } } }
        }
      }
    },
    "/api/v1/workloads/{project}/{slug}/logs": {
      "parameters": [
        { "name": "project", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "follow", "in": "query", "schema": { "type": "boolean", "default": false } },
        { "name": "tail", "in": "query", "schema": { "type": "integer", "default": 200 } },
        { "name": "service", "in": "query", "explode": true, "schema": { "type": "array", "items": { "type": "string" } }, "description": "Restrict the stream to one or more compose services (repeatable). Empty → every service streams." }
      ],
      "get": {
        "tags": ["workloads"],
        "summary": "Stream container logs (chunked)",
        "description": "Chunked text/plain. follow=true tails new lines until the client disconnects (which kills the underlying docker process). Repeat ?service=<name> to filter — empty means all services.",
        "responses": {
          "200": { "description": "Log stream", "content": { "text/plain": { "schema": { "type": "string" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/projects": {
      "get": {
        "tags": ["projects"],
        "summary": "List registered projects",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ProjectListItem" } } } } }
        }
      },
      "post": {
        "tags": ["projects"],
        "summary": "Write a manifest and register the project",
        "description": "Writes the supplied manifest verbatim to <repo>/.pier.toml (creating or overwriting) and adds (project_name, repo_path) to the state DB. Typical flow: call POST /scan first to get a `suggested_manifest`, edit, then POST here.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectCreateRequest" } } }
        },
        "responses": {
          "200": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectCreateResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/v1/projects/scan": {
      "post": {
        "tags": ["projects"],
        "summary": "Dry-run pier init — propose a manifest from a repo",
        "description": "Reads the repo (compose detection, env scan, existing manifest if any) and returns the manifest a `pier init -y` would write. No files are touched. The UI uses `suggested_manifest` to pre-fill an edit form.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectScanRequest" } } }
        },
        "responses": {
          "200": { "description": "Proposal", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectScanResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "422": { "description": "Repo cannot be scanned (missing, no compose file, etc.)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/projects/{name}": {
      "parameters": [
        { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "tags": ["projects"],
        "summary": "Get one project (manifest + counts)",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["projects"],
        "summary": "Unregister a project",
        "description": "Removes the registry row only — does NOT delete the manifest, worktrees, or running workloads. Idempotent (200 on missing).",
        "responses": {
          "200": { "description": "Unregistered" }
        }
      }
    },
    "/api/v1/projects/{name}/worktrees": {
      "parameters": [
        { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "tags": ["projects"],
        "summary": "List git worktrees of the project's repo",
        "description": "Each entry is annotated with its workload (status, URLs, containers) when one is registered for that path.",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/WorktreeListItem" } } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/worktrees": {
      "post": {
        "tags": ["worktrees"],
        "summary": "Create a worktree (and optionally up the workload)",
        "description": "Specify either `project` (resolves the repo from the registry — preferred) or `repo` (absolute path — legacy). When both are set, `project` wins.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorktreeCreateRequest" } } }
        },
        "responses": {
          "200": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorktreeCreateResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/v1/worktrees/{slug}": {
      "parameters": [
        { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "project", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Project name (resolves repo from registry — preferred)" },
        { "name": "repo", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Absolute path of the primary worktree (legacy alternative to project)" }
      ],
      "delete": {
        "tags": ["worktrees"],
        "summary": "Stop and remove a worktree",
        "description": "Either `project` or `repo` query parameter is required (`project` wins when both are set). Always passes --force to `git worktree remove`. When the rm fails part-way through (typical: container left root-owned files in a bind mount), pier prunes the dangling git metadata and surfaces a 200 + warning so the caller can show \"manual sudo rm needed\".",
        "responses": {
          "200": { "description": "Removed (may include warning)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ActionResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/config": {
      "get": {
        "tags": ["infra"],
        "summary": "Pier install state",
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Config" } } } } }
      }
    },
    "/api/v1/doctor": {
      "get": {
        "tags": ["infra"],
        "summary": "Health check report",
        "description": "Mirrors `pier doctor` (read-only).",
        "responses": { "200": { "description": "Report", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DoctorReport" } } } } }
      }
    },
    "/api/v1/events": {
      "get": {
        "tags": ["events"],
        "summary": "Server-Sent Events stream",
        "description": "**⚠️ Not testable from this UI** — Swagger UI cannot render an open `text/event-stream`; the request will hang forever. Test with `curl -N http://<bind>:<port>/api/v1/events` or with a browser `EventSource('/api/v1/events')`.\n\nLong-lived text/event-stream. Initial `state.snapshot` event with the full workload list, followed by transitions (`workload.up`, `workload.crashed`, `workload.restarting`, `workload.removed`, `doctor.fail`, `doctor.recovered`) and `ping` heartbeats every 30s. Browsers consume directly via EventSource. Slow consumers see events dropped — they can recover by reconnecting and reading the new `state.snapshot`.",
        "responses": {
          "200": {
            "description": "SSE stream",
            "content": { "text/event-stream": { "schema": { "type": "string" } } }
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "NotFound": { "description": "Resource not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "BadRequest": { "description": "Invalid request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Conflict": { "description": "State conflict (manifest project name disagrees with URL)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "InternalError": { "description": "Server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
    },
    "schemas": {
      "Workload": {
        "type": "object",
        "required": ["project", "slug", "branch", "kind", "status", "urls", "containers", "worktree_path", "started_at", "uptime_seconds"],
        "properties": {
          "project": { "type": "string" },
          "slug": { "type": "string" },
          "branch": { "type": "string" },
          "kind": { "type": "string", "enum": ["compose"] },
          "status": { "type": "string", "description": "docker State.Status — running/exited/restarting/missing/unknown" },
          "urls": { "type": "array", "items": { "$ref": "#/components/schemas/URL" } },
          "containers": { "type": "array", "items": { "$ref": "#/components/schemas/Container" } },
          "worktree_path": { "type": "string" },
          "worktree_missing": { "type": "boolean", "description": "True when the recorded worktree path no longer exists on disk" },
          "container_id": { "type": "string" },
          "started_at": { "type": "string", "format": "date-time" },
          "uptime_seconds": { "type": "integer" },
          "error": { "type": "string", "description": "non-fatal error encountered while building the view (e.g. manifest unreadable, docker ps failure)" }
        }
      },
      "URL": {
        "type": "object",
        "required": ["url", "label"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "label": { "type": "string" },
          "default": { "type": "boolean", "description": "true for the bare-slug alias when [stack].service is set" }
        }
      },
      "Container": {
        "type": "object",
        "required": ["name", "image", "status"],
        "properties": {
          "name": { "type": "string" },
          "image": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "Config": {
        "type": "object",
        "required": ["mode", "tld", "bind_ip", "answer_ip", "traefik_network", "version"],
        "properties": {
          "mode": { "type": "string", "enum": ["local", "server"] },
          "tld": { "type": "string" },
          "bind_ip": { "type": "string" },
          "answer_ip": { "type": "string" },
          "traefik_network": { "type": "string" },
          "external_traefik": { "type": "string" },
          "headscale_records_path": { "type": "string" },
          "version": { "type": "string" }
        }
      },
      "Check": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
          "detail": { "type": "string" },
          "fix_hint": { "type": "string" }
        }
      },
      "DoctorReport": {
        "type": "object",
        "required": ["failed", "checks"],
        "properties": {
          "failed": { "type": "boolean" },
          "checks": { "type": "array", "items": { "$ref": "#/components/schemas/Check" } }
        }
      },
      "ActionResponse": {
        "type": "object",
        "required": ["project", "slug", "status"],
        "properties": {
          "project": { "type": "string" },
          "slug": { "type": "string" },
          "status": { "type": "string", "enum": ["running", "down", "removed"] },
          "warning": { "type": "string", "description": "set when the action partially succeeded — e.g. state row dropped but worktree dir still present" }
        }
      },
      "UpRequest": {
        "type": "object",
        "properties": {
          "worktree_path": { "type": "string", "description": "Absolute path of the worktree, required only when no state row exists for (project, slug)" }
        }
      },
      "WorktreeCreateRequest": {
        "type": "object",
        "required": ["slug"],
        "description": "Specify either `project` (resolves repo from registry) or `repo` (absolute path). At least one is required; `project` wins.",
        "properties": {
          "project": { "type": "string", "description": "Project name from the registry — resolved to the repo path server-side" },
          "repo":    { "type": "string", "description": "Absolute path of the primary worktree (legacy alternative to project)" },
          "slug":    { "type": "string", "description": "Doubles as the dir name and the workload slug" },
          "branch":  { "type": "string", "description": "Defaults to slug when omitted" },
          "from":    { "type": "string", "description": "Base ref override; defaults to manifest [worktree].base_ref then main/master then HEAD" },
          "up":      { "type": "boolean", "description": "When true, runs pier up after materialization and includes the resulting workload in the response" }
        }
      },
      "WorktreeCreateResponse": {
        "type": "object",
        "required": ["project", "slug", "branch", "worktree_path"],
        "properties": {
          "project": { "type": "string" },
          "slug": { "type": "string" },
          "branch": { "type": "string" },
          "worktree_path": { "type": "string" },
          "workload": { "$ref": "#/components/schemas/Workload" }
        }
      },
      "WorktreeListItem": {
        "type": "object",
        "required": ["path", "slug", "branch", "has_workload"],
        "properties": {
          "path":         { "type": "string", "description": "Absolute worktree path" },
          "slug":         { "type": "string", "description": "Workload slug when has_workload, otherwise basename of path" },
          "branch":       { "type": "string", "description": "Empty when detached" },
          "missing":      { "type": "boolean", "description": "True when the path is no longer present on disk but pier still has state to clean up" },
          "has_workload": { "type": "boolean" },
          "workload":     { "$ref": "#/components/schemas/Workload" }
        }
      },
      "ProjectListItem": {
        "type": "object",
        "required": ["name", "repo_path", "registered_at", "has_manifest", "active_workloads"],
        "properties": {
          "name":             { "type": "string" },
          "repo_path":        { "type": "string" },
          "registered_at":    { "type": "string", "format": "date-time" },
          "has_manifest":     { "type": "boolean", "description": "True when <repo>/.pier.toml parses successfully" },
          "active_workloads": { "type": "integer" }
        }
      },
      "Project": {
        "type": "object",
        "required": ["name", "repo_path", "registered_at", "has_manifest", "active_workloads", "worktree_count"],
        "properties": {
          "name":             { "type": "string" },
          "repo_path":        { "type": "string" },
          "registered_at":    { "type": "string", "format": "date-time" },
          "has_manifest":     { "type": "boolean" },
          "manifest":         { "$ref": "#/components/schemas/Manifest" },
          "active_workloads": { "type": "integer" },
          "worktree_count":   { "type": "integer" }
        }
      },
      "ProjectScanRequest": {
        "type": "object",
        "required": ["repo"],
        "properties": {
          "repo": { "type": "string", "description": "Absolute path of the repo to scan" }
        }
      },
      "ProjectScanResponse": {
        "type": "object",
        "required": ["repo", "toplevel", "manifest_path", "services", "is_reinit"],
        "properties": {
          "repo":              { "type": "string" },
          "toplevel":          { "type": "string", "description": "Git toplevel — equal to repo when scan was given the toplevel directly" },
          "manifest_path":     { "type": "string" },
          "compose_file":      { "type": "string" },
          "services":          { "type": "array", "items": { "$ref": "#/components/schemas/ScanService" } },
          "existing_manifest": { "$ref": "#/components/schemas/Manifest" },
          "suggested_manifest":{ "$ref": "#/components/schemas/Manifest" },
          "is_reinit":         { "type": "boolean" }
        }
      },
      "ScanService": {
        "type": "object",
        "required": ["name", "image", "port"],
        "properties": {
          "name":  { "type": "string" },
          "image": { "type": "string" },
          "port":  { "type": "integer", "description": "First published container port" }
        }
      },
      "ProjectCreateRequest": {
        "type": "object",
        "required": ["repo", "manifest"],
        "properties": {
          "repo":     { "type": "string", "description": "Absolute path of the repo to write into" },
          "manifest": { "$ref": "#/components/schemas/Manifest" },
          "private":  { "type": "boolean", "description": "When true and on first init, gitignore .pier.toml so the manifest stays per-machine. Default false matches the CLI default (the manifest is committed so secondary worktrees and other contributors inherit the project's pier config). On re-init this flag is ignored — gitignore decisions made at first init are not revisited." }
        }
      },
      "ProjectCreateResponse": {
        "type": "object",
        "required": ["repo", "project_name", "manifest_path", "registered", "merged"],
        "properties": {
          "repo":          { "type": "string" },
          "project_name":  { "type": "string" },
          "manifest_path": { "type": "string" },
          "registered":    { "type": "boolean", "description": "False when the manifest was written but the registry refused (conflict on a different mapping)" },
          "merged":        { "type": "boolean", "description": "True when a .pier.toml already existed at the repo (the write replaced it)" },
          "warning":       { "type": "string" }
        }
      },
      "Manifest": {
        "type": "object",
        "description": "Mirror of the .pier.toml on-disk format. JSON tags match TOML tags.",
        "required": ["project", "stack", "expose"],
        "properties": {
          "project":     { "$ref": "#/components/schemas/ManifestProject" },
          "stack":       { "$ref": "#/components/schemas/ManifestStack" },
          "expose":      { "type": "array", "items": { "$ref": "#/components/schemas/ManifestExpose" } },
          "service":     { "type": "object", "additionalProperties": { "$ref": "#/components/schemas/ManifestService" }, "description": "compose service -> per-service overrides" },
          "env":         { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": { "type": "string" } }, "description": "service -> key -> value" },
          "materialize": { "$ref": "#/components/schemas/ManifestMaterialize" },
          "hooks":       { "$ref": "#/components/schemas/ManifestHooks" },
          "watch":       { "$ref": "#/components/schemas/ManifestWatch" },
          "worktree":    { "$ref": "#/components/schemas/ManifestWorktree" }
        }
      },
      "ManifestProject": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":        { "type": "string" },
          "base_domain": { "type": "string", "description": "Defaults to <name>.<installed-tld> at runtime when empty" }
        }
      },
      "ManifestStack": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind":           { "type": "string", "enum": ["compose", "dockerfile"] },
          "file":           { "type": "string", "description": "Compose file path (for kind=compose)" },
          "dockerfile":     { "type": "string", "description": "Dockerfile path (kind=dockerfile, Phase 3)" },
          "service":        { "type": "string", "description": "Service that gets the bare-slug alias" },
          "match_host_uid": { "type": "boolean", "description": "Inject user: <uid>:<gid> in the compose override (distroless/nonroot fix)" }
        }
      },
      "ManifestExpose": {
        "type": "object",
        "required": ["service", "port"],
        "properties": {
          "service": { "type": "string" },
          "port":    { "type": "integer" },
          "host":    { "type": "string", "description": "Sub-domain label, defaults to service when empty" }
        }
      },
      "ManifestService": {
        "type": "object",
        "properties": {
          "match_host_uid": { "type": "boolean", "description": "Inject user: <uid>:<gid> for this compose service, exposed or not" }
        }
      },
      "ManifestMaterialize": {
        "type": "object",
        "properties": {
          "symlinks":    { "type": "array", "items": { "type": "string" } },
          "snapshots":   { "type": "array", "items": { "type": "string" } },
          "post_create": { "type": "array", "items": { "type": "string" } },
          "pre_remove":  { "type": "array", "items": { "type": "string" } }
        }
      },
      "ManifestHooks": {
        "type": "object",
        "properties": {
          "pre_up":    { "type": "array", "items": { "type": "string" } },
          "post_up":   { "type": "array", "items": { "type": "string" } },
          "pre_down":  { "type": "array", "items": { "type": "string" } },
          "post_down": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ManifestWatch": {
        "type": "object",
        "properties": {
          "paths":     { "type": "array", "items": { "type": "string" } },
          "on_change": { "type": "string", "enum": ["rebuild", "restart"] }
        }
      },
      "ManifestWorktree": {
        "type": "object",
        "properties": {
          "dir":      { "type": "string", "description": "Where pier worktree add places trees (relative paths resolve against the primary)" },
          "base_ref": { "type": "string", "description": "Default base ref for new worktree branches" }
        }
      },
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": { "error": { "type": "string" } }
      }
    }
  }
}
